# ============================================================
# Uppi — Monorepo Central Environment Configuration Example
# ============================================================
# Copie este arquivo para .env nas pastas apropriadas:
#   - Para o frontend: apps/rider-frontend/.env
#   - Para o backend: supabase/.env
# NUNCA commite arquivos .env reais no controle de versão!
# ============================================================

# ────────────────────────────────────────────────────────────
# 📱 FRONTEND — apps/rider-frontend/.env
# ────────────────────────────────────────────────────────────
APP_NAME=Uppi
APP_URL=https://uppi.app

# Google Maps API Key (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_MAP_API_KEY=AIzaSy_SUA_CHAVE_AQUI

# Mapbox Token (mapbox.com > Account > Tokens) — usado para mapas alternativos
MAPBOX_TOKEN=pk.eyJ1_SEU_TOKEN_MAPBOX_AQUI

# Supabase (Dashboard > Settings > API)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9_SUA_ANON_KEY_AQUI

# Sentry DSN (sentry.io > Settings > Projects > Client Keys)
SENTRY_DSN=https://HASH@o123456.ingest.sentry.io/1234567


# ────────────────────────────────────────────────────────────
# ⚡ BACKEND & EDGE FUNCTIONS — supabase/.env
# ────────────────────────────────────────────────────────────
# JSON da conta de serviço do Firebase (necessário para FCM / Auth)
FIREBASE_SERVICE_ACCOUNT_JSON='{ \
  "type": "service_account", \
  "project_id": "seu-projeto-firebase", \
  "private_key_id": "sua-private-key-id", \
  "private_key": "-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n", \
  "client_email": "firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com", \
  "client_id": "seu-client-id", \
  "auth_uri": "https://accounts.google.com/o/oauth2/auth", \
  "token_uri": "https://oauth2.googleapis.com/token", \
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs", \
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40seu-projeto.iam.gserviceaccount.com", \
  "universe_domain": "googleapis.com" \
}'

# Chaves de API de terceiros para o backend
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxx-xxxx-xxxx-xxxxx
MERCADO_PAGO_WEBHOOK_SECRET=xxxxxx
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+123456789
