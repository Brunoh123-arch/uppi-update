# ============================================================
# Uppi — Super App (Passageiro + Motorista)
# Variaveis de Ambiente — Rider Frontend
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com valores reais no repositorio!
# Consulte docs/RUNBOOKS.md para instrucoes completas de setup.
# ============================================================

APP_NAME=Uppi

# Google Maps API Key (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_MAP_API_KEY=AIzaSy_SUA_CHAVE_AQUI

# Mapbox Token (mapbox.com > Account > Tokens) — usado para mapas alternativos
MAPBOX_TOKEN=pk.eyJ1_SEU_TOKEN_MAPBOX_AQUI

# Supabase (Dashboard > Settings > API)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9_SUA_ANON_KEY_AQUI

# URL publica do app (usado para deep links e compartilhamento de corridas)
APP_URL=https://uppi.app

# Sentry DSN (sentry.io > Settings > Projects > Client Keys)
SENTRY_DSN=https://HASH@o123456.ingest.sentry.io/1234567